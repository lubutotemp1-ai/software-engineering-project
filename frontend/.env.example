# Frontend Environment Variables
# Copy this file to .env in the frontend folder and fill in your values

# API Endpoint (your Render backend URL)
REACT_APP_API_URL=https://your-render-api-url.onrender.com

# Stripe Public Key (for checkout)
# Get this from https://dashboard.stripe.com/apikeys
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key_here
